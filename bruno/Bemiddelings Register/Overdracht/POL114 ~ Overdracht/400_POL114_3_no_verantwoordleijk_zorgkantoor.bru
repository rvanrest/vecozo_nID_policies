meta {
  name: 400_POL114_3_no_verantwoordleijk_zorgkantoor
  type: graphql
  seq: 3
}

post {
  url: {{pep-url}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{jwt_token}}
}

body:graphql {
  query Overdracht(
    $overdrachtID: UUID!
    $OverdrachtDatum: Date!
    $OverdrachtDatumMinus1Dag: Date!
  ) {
    overdracht(
      where: {
        overdrachtID: { eq: $overdrachtID }
        overdrachtDatum: { eq: $OverdrachtDatum }
      }
    ) {
      overdrachtID
      verantwoordelijkZorgkantoor
      overdrachtDatum
      verhuisDatum
      vaststellingMoment
      bemiddeling {
        bemiddelingID
        wlzIndicatieID
        verantwoordelijkZorgkantoor
        verantwoordelijkheidIngangsdatum
        verantwoordelijkheidEinddatum
        client {
          clientID
          bsn
          leefeenheid
          huisarts
          communicatievorm
          taal
          contactgegevens(
            where: {
              or: [
                { einddatum: { gt: $OverdrachtDatumMinus1Dag } }
                { einddatum: { eq: null } }
              ]
            }
          ) {
            clientContactgegevensID
            adressoort
            straatnaam
            huisnummer
            huisletter
            huisnummertoevoeging
            postcode
            plaatsnaam
            land
            emailadres
            telefoonnummer01
            landnummer01
            telefoonnummer02
            landnummer02
            ingangsdatum
            einddatum
          }
          contactpersoon(
            where: {
              or: [
                { einddatum: { gt: $OverdrachtDatumMinus1Dag } }
                { einddatum: { eq: null } }
              ]
            }
          ) {
            contactpersoonID
            contactgegevens(
              where: {
              or: [
                { einddatum: { gt: $OverdrachtDatumMinus1Dag } }
                { einddatum: { eq: null } }
              ]
            }
            ) {
              contactpersoonContactgegevensID
              adressoort
              straatnaam
              huisnummer
              huisnummertoevoeging
              postcode
              plaatsnaam
              land
              emailadres
              telefoonnummer01
              landnummer01
              telefoonnummer02
              landnummer02
              ingangsdatum
              einddatum
            }
            relatienummer
            volgorde
            soortRelatie
            rol
            relatienummer
            geslachtsnaam
            voorvoegselGeslachtsnaam
            voornamen
            voorletters
            roepnaam
            naamgebruik
            geslacht
            geboortedatum
            geboortedatumgebruik
            ingangsdatum
            einddatum
          }
        }
        regiehouder(
          where: {
            ingangsdatum: { ngt: $OverdrachtDatum }
            or: [
              { einddatum: { gte: $OverdrachtDatumMinus1Dag } }
              { einddatum: { eq: null } }
            ]
          }
        ) {
          regiehouderID
          instelling
          ingangsdatum
          einddatum
          regierol
        }
      }
      overdrachtspecificatie {
        overdrachtspecificatieID
        leveringsstatus
        leveringsstatusClassificatie
        oorspronkelijkeToewijzingEinddatum
        bemiddelingspecificatie {
          bemiddelingspecificatieID
          leveringsvorm
          zzpCode
          toewijzingIngangsdatum
          toewijzingEinddatum
          instelling
          uitvoerendZorgkantoor
          vaststellingMoment
          percentage
          opname
          redenIntrekking
          etmalen
          instellingBestemming
          soortToewijzing
        }
      }
    }
  }
}

body:graphql:vars {
  {
    "overdrachtID": "c37239b0-9e3d-4c00-88fd-01f37e590fc0",
    "OverdrachtDatum": "2023-04-17",
    "OverdrachtDatumMinus1Dag": "2023-04-16"
  
  }
}

assert {
  res.status: eq 400
  JSON.stringify(res.body): contains A where 'verantwoordelijkZorgkantoor' equals is required.
}

script:pre-request {
  if(req.getExecutionMode() == "runner" || bru.getEnvVar("impersonation") || bru.getGlobalEnvVar("impersonation")){
    bru.setVar("impersonation","uzovi:5151")
  }else{
    bru.setVar("impersonation","")
  }
  bru.setVar("scope","registers/wlzbemiddelingsregister/bemiddelingen/bemiddeling:read")
  bru.setVar("graphql-url", bru.getFolderVar("graphql-url"))
  const requestResponse = await bru.runRequest("token");
}
